{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@env": ["node_modules/react-native-dotenv"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "node_modules/react-native-dotenv",
    "src/**/*",
    "components/**/*",
    "App.tsx",
    "env.d.ts"
  ]
}
